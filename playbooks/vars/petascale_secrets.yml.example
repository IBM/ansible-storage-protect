---
# Petascale Data Protection - Secrets Template
#
# This is a template file for storing sensitive credentials.
# Copy this file to petascale_secrets.yml and encrypt it with Ansible Vault.
#
# Steps to use:
# 1. Copy this file: cp petascale_secrets.yml.example petascale_secrets.yml
# 2. Edit petascale_secrets.yml with your actual passwords
# 3. Encrypt the file: ansible-vault encrypt petascale_secrets.yml
# 4. Create vault password file: echo "your-vault-password" > vault_pass.txt
# 5. Secure the password file: chmod 600 vault_pass.txt
# 6. Add to .gitignore: echo "vault_pass.txt" >> .gitignore
# 7. Add to .gitignore: echo "petascale_secrets.yml" >> .gitignore
#
# Usage:
#   ansible-playbook petascale_deploy.yml \
#     -e @vars/petascale_large_vars.yml \
#     -e @vars/petascale_secrets.yml \
#     --vault-password-file vault_pass.txt

# ============================================================================
# SSL Configuration
# ============================================================================

# SSL certificate password
# Used for securing server communications
vault_ssl_password: "CHANGE_ME_SecureSSLPassword123!"

# ============================================================================
# Server Authentication
# ============================================================================

# IBM Storage Protect Server password
# Used for server-to-server communication
vault_server_password: "CHANGE_ME_SecureServerPassword456!"

# ============================================================================
# Administrative Access
# ============================================================================

# Admin user password
# Used for administrative operations via dsmadmc
vault_admin_password: "CHANGE_ME_SecureAdminPassword789!"

# ============================================================================
# Database Backup
# ============================================================================

# Database backup password
# Used for encrypting database backups
vault_dbbk_password: "CHANGE_ME_SecureDBBackupPassword012!"

# ============================================================================
# Instance User
# ============================================================================

# TSM instance user password
# Used for the tsminst1 system user
vault_tsm_user_password: "CHANGE_ME_SecureTSMUserPassword345!"

# ============================================================================
# Password Requirements
# ============================================================================

# For production petascale deployments, ensure passwords meet these criteria:
#
# 1. Minimum length: 12 characters
# 2. Complexity requirements:
#    - At least one uppercase letter (A-Z)
#    - At least one lowercase letter (a-z)
#    - At least one digit (0-9)
#    - At least one special character (!@#$%^&*()_+-=[]{}|;:,.<>?)
# 3. No dictionary words
# 4. No personal information
# 5. Unique for each credential
# 6. Regularly rotated (every 90 days recommended)
#
# Example strong password: "Ps@1eD@t@Pr0t3ct!2026"

# ============================================================================
# Vault Operations
# ============================================================================

# View encrypted file:
#   ansible-vault view petascale_secrets.yml --vault-password-file vault_pass.txt
#
# Edit encrypted file:
#   ansible-vault edit petascale_secrets.yml --vault-password-file vault_pass.txt
#
# Rekey (change vault password):
#   ansible-vault rekey petascale_secrets.yml --vault-password-file vault_pass.txt
#
# Decrypt file (for backup/migration):
#   ansible-vault decrypt petascale_secrets.yml --vault-password-file vault_pass.txt
#
# Encrypt file again:
#   ansible-vault encrypt petascale_secrets.yml --vault-password-file vault_pass.txt

# ============================================================================
# Security Best Practices
# ============================================================================

# 1. Never commit unencrypted secrets to version control
# 2. Never commit vault_pass.txt to version control
# 3. Store vault password securely (password manager, secrets management system)
# 4. Use different passwords for different environments (dev, test, prod)
# 5. Implement password rotation policy
# 6. Audit access to vault files
# 7. Use role-based access control (RBAC)
# 8. Enable audit logging for administrative operations
# 9. Implement multi-factor authentication where possible
# 10. Regular security reviews and penetration testing

# ============================================================================
# Petascale Security Considerations
# ============================================================================

# For petascale deployments protecting 500+ TB of data:
#
# 1. Network Security:
#    - Dedicated backup network (separate VLAN)
#    - Firewall rules for SP Server ports (1500, 1543)
#    - SSL/TLS for all client connections
#    - Certificate-based authentication
#
# 2. Data Security:
#    - Encryption at rest (storage pools)
#    - Encryption in transit (SSL/TLS)
#    - Deduplication with encryption
#    - Secure key management
#
# 3. Access Control:
#    - Role-based access control (RBAC)
#    - Principle of least privilege
#    - Regular access reviews
#    - Strong authentication policies
#
# 4. Compliance:
#    - Data retention policies
#    - Audit logging
#    - Compliance reporting
#    - Data sovereignty requirements
#
# 5. Disaster Recovery:
#    - Offsite backup copies
#    - Server-to-server replication
#    - Regular DR testing
#    - Documented recovery procedures

# ============================================================================
# Additional Resources
# ============================================================================

# For more information on security best practices:
# - IBM Storage Protect Security Guide
# - Ansible Vault Documentation: https://docs.ansible.com/ansible/latest/user_guide/vault.html
# - NIST Cybersecurity Framework
# - CIS Benchmarks for IBM Storage Protect