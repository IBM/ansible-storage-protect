# Petascale Data Protection - Inventory Example
#
# This is an example inventory file for petascale IBM Storage Protect deployments.
# Copy this file and customize it for your environment.
#
# Steps to use:
# 1. Copy this file: cp petascale.ini.example petascale.ini
# 2. Edit petascale.ini with your actual host information
# 3. Test connectivity: ansible -i petascale.ini sp_servers -m ping
#
# Reference:
# - Design: docs/design/design-petascale.md
# - User Guide: docs/guides/petascale-guide.md

# ============================================================================
# SP Server Hosts (Petascale Configuration)
# ============================================================================

[sp_servers]
# Primary petascale SP Server
sp-server-01 ansible_host=192.168.1.100 ansible_user=root

# Additional servers for horizontal scaling (optional)
# sp-server-02 ansible_host=192.168.1.101 ansible_user=root
# sp-server-03 ansible_host=192.168.1.102 ansible_user=root

[sp_servers:vars]
# Python interpreter (ensure Python 3.9+ is installed)
ansible_python_interpreter=/usr/bin/python3

# Connection settings
ansible_connection=ssh
ansible_ssh_common_args='-o StrictHostKeyChecking=no'

# Privilege escalation
ansible_become=yes
ansible_become_method=sudo

# ============================================================================
# Environment-Specific Groups
# ============================================================================

[petascale_production]
sp-server-01

[petascale_staging]
# sp-server-staging ansible_host=192.168.1.200 ansible_user=root

[petascale_development]
# sp-server-dev ansible_host=192.168.1.201 ansible_user=root

# ============================================================================
# Geographic Distribution (for multi-site deployments)
# ============================================================================

[datacenter_primary]
sp-server-01

[datacenter_secondary]
# sp-server-02

[datacenter_dr]
# sp-server-03

# ============================================================================
# Role-Based Groups
# ============================================================================

[sp_primary_servers]
sp-server-01

[sp_replica_servers]
# sp-server-02
# sp-server-03

# ============================================================================
# Client Hosts (for BA Client deployments)
# ============================================================================

[ba_clients]
# client-01 ansible_host=192.168.2.10 ansible_user=root
# client-02 ansible_host=192.168.2.11 ansible_user=root
# client-03 ansible_host=192.168.2.12 ansible_user=root

[ba_clients:vars]
ansible_python_interpreter=/usr/bin/python3
ansible_connection=ssh

# ============================================================================
# Storage Agent Hosts (for LAN-Free backups)
# ============================================================================

[storage_agents]
# storage-agent-01 ansible_host=192.168.3.10 ansible_user=root

[storage_agents:vars]
ansible_python_interpreter=/usr/bin/python3

# ============================================================================
# Operations Center Hosts
# ============================================================================

[operations_center]
# oc-server-01 ansible_host=192.168.4.10 ansible_user=root

[operations_center:vars]
ansible_python_interpreter=/usr/bin/python3

# ============================================================================
# All IBM Storage Protect Infrastructure
# ============================================================================

[sp_infrastructure:children]
sp_servers
ba_clients
storage_agents
operations_center

# ============================================================================
# Host-Specific Variables (host_vars)
# ============================================================================

# For host-specific customization, create files in host_vars/ directory:
#
# host_vars/sp-server-01.yml:
# ---
# server_name: "PETASCALE-SP01"
# instance_dir: "/tsminst1"
# server_size: "large"
#
# host_vars/sp-server-02.yml:
# ---
# server_name: "PETASCALE-SP02"
# instance_dir: "/tsminst1"
# server_size: "large"

# ============================================================================
# Group-Specific Variables (group_vars)
# ============================================================================

# For group-specific customization, create files in group_vars/ directory:
#
# group_vars/sp_servers.yml:
# ---
# sp_server_version: "8.1.27.0"
# server_blueprint: true
# storage_prepare_size: "large"
#
# group_vars/petascale_production.yml:
# ---
# backup_start_time: "22:00"
# maxcap: "500G"
# dbbk_streams: "8"

# ============================================================================
# Network Configuration Notes
# ============================================================================

# For petascale deployments, consider:
#
# 1. Dedicated Backup Network:
#    - Separate VLAN for backup traffic
#    - 10/25/40/100 GbE network interfaces
#    - Jumbo frames (MTU 9000) enabled
#    - QoS configuration for backup traffic
#
# 2. Management Network:
#    - Separate network for Ansible management
#    - SSH access for automation
#    - Monitoring and alerting
#
# 3. Client Network:
#    - Network connectivity from all clients
#    - Firewall rules for ports 1500, 1543
#    - Load balancing (optional)
#
# 4. Storage Network:
#    - High-speed connection to storage systems
#    - Redundant paths for availability
#    - SAN/NAS connectivity as needed

# ============================================================================
# Hardware Requirements (Petascale - Large Configuration)
# ============================================================================

# Minimum requirements for sp-server-01:
#
# CPU: 32+ cores
# RAM: 128+ GB
# Storage:
#   - Database: 4-4.05 TB (multiple disks)
#   - Active Log: 550-600 GB (LVM striped)
#   - Archive Log: 4-4.05 TB (LVM striped)
#   - File Storage: 500-500.05 TB (multiple disks)
#   - Backup: 16-16.05 TB (multiple disks)
# Network: 10+ GbE (25/40/100 GbE recommended)
# OS: RHEL 7.x/8.x/9.x, SLES 12/15, Ubuntu 18.04/20.04/22.04

# ============================================================================
# Testing Connectivity
# ============================================================================

# Test basic connectivity:
#   ansible -i petascale.ini sp_servers -m ping
#
# Test privilege escalation:
#   ansible -i petascale.ini sp_servers -m shell -a "whoami" -b
#
# Gather facts:
#   ansible -i petascale.ini sp_servers -m setup
#
# Check disk space:
#   ansible -i petascale.ini sp_servers -m shell -a "df -h"
#
# Check available disks:
#   ansible -i petascale.ini sp_servers -m shell -a "lsblk"

# ============================================================================
# Security Considerations
# ============================================================================

# 1. SSH Key Authentication:
#    - Use SSH keys instead of passwords
#    - Disable password authentication
#    - Use ssh-agent for key management
#
# 2. Ansible Vault:
#    - Encrypt sensitive variables
#    - Use vault password file
#    - Never commit unencrypted secrets
#
# 3. Network Security:
#    - Firewall rules for required ports only
#    - VPN for remote access
#    - Network segmentation
#
# 4. Access Control:
#    - Limit sudo access
#    - Use role-based access control
#    - Regular access reviews

